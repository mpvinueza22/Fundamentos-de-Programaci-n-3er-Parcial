#include <stdio.h>

int main() 
{
    int numero, d1, d2, d3, d4, temp, num_cifrado, num_descifrado;
    int *p_num = &numero, *p_temp = &temp;
    int *p1 = &d1, *p2 = &d2, *p3 = &d3, *p4 = &d4;
    int *p_cif = &num_cifrado, *p_des = &num_descifrado;

    printf("Introduce un entero de cuatro digitos para cifrar: ");
    scanf("%d", p_num);

    *p1 = *p_num / 1000;
    *p2 = (*p_num / 100) % 10;
    *p3 = (*p_num / 10) % 10;
    *p4 = *p_num % 10;

    *p1 = (*p1 + 7) % 10;
    *p2 = (*p2 + 7) % 10;
    *p3 = (*p3 + 7) % 10;
    *p4 = (*p4 + 7) % 10;

    *p_temp = *p1; *p1 = *p3; *p3 = *p_temp;
    *p_temp = *p2; *p2 = *p4; *p4 = *p_temp;

   
    *p_cif = (*p1 * 1000) + (*p2 * 100) + (*p3 * 10) + *p4;
    printf("Entero cifrado: %04d\n", *p_cif);


    *p1 = *p_cif / 1000;
    *p2 = (*p_cif / 100) % 10;
    *p3 = (*p_cif / 10) % 10;
    *p4 = *p_cif % 10;

   
    *p_temp = *p1; *p1 = *p3; *p3 = *p_temp;
    *p_temp = *p2; *p2 = *p4; *p4 = *p_temp;

    
    *p1 = (*p1 < 7) ? (*p1 + 10 - 7) : (*p1 - 7);
    *p2 = (*p2 < 7) ? (*p2 + 10 - 7) : (*p2 - 7);
    *p3 = (*p3 < 7) ? (*p3 + 10 - 7) : (*p3 - 7);
    *p4 = (*p4 < 7) ? (*p4 + 10 - 7) : (*p4 - 7);

   
    *p_des = (*p1 * 1000) + (*p2 * 100) + (*p3 * 10) + *p4;
    printf("Entero descifrado (original): %04d\n", *p_des);

    return 0;
}
