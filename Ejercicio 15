#include <stdio.h>

int main() 
{
    int n, i, temp;
    int *p_n = &n, *p_i = &i, *p_temp = &temp;

    printf("Ingrese el limite n para la tabla de numeros romanos: ");
    scanf("%d", p_n);

    printf("\nDECIMAL\tROMANO\n");
    for (*p_i = 1; *p_i <= *p_n; (*p_i)++) 
    {
        *p_temp = *p_i;
        printf("%d\t", *p_temp);

        while (*p_temp >= 1000) { printf("M");  *p_temp -= 1000; }
        if (*p_temp >= 900)     { printf("CM"); *p_temp -= 900;  }
        if (*p_temp >= 500)     { printf("D");  *p_temp -= 500;  }
        if (*p_temp >= 400)     { printf("CD"); *p_temp -= 400;  }
        while (*p_temp >= 100)  { printf("C");  *p_temp -= 100;  }
        if (*p_temp >= 90)      { printf("XC"); *p_temp -= 90;   }
        if (*p_temp >= 50)      { printf("L");  *p_temp -= 50;   }
        if (*p_temp >= 40)      { printf("XL"); *p_temp -= 40;   }
        while (*p_temp >= 10)   { printf("X");  *p_temp -= 10;   }
        if (*p_temp >= 9)       { printf("IX"); *p_temp -= 9;    }
        if (*p_temp >= 5)       { printf("V");  *p_temp -= 5;    }
        if (*p_temp >= 4)       { printf("IV"); *p_temp -= 4;    }
        while (*p_temp >= 1)    { printf("I");  *p_temp -= 1;    }
        
        printf("\n");
    }

    return 0;
}
